# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos (PostgreSQL) ─────────────────────────────────
# En Render, DATABASE_URL se setea automáticamente
DATABASE_URL=postgresql://user:password@localhost:5432/casino_eldorado

# ── JWT Secrets (generá strings largos y aleatorios) ───────────
JWT_SECRET=cambia_esto_por_un_string_largo_y_random_para_usuarios
ADMIN_JWT_SECRET=cambia_esto_por_otro_string_largo_y_random_para_admin

# ── Admin ──────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esta_clave_admin_a_algo_seguro

# ── MercadoPago ────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-XXXXXXXXXX
MP_PUBLIC_KEY=APP_USR-XXXXXXXXXX

# ── CORS ───────────────────────────────────────────────────────
# En producción, cambiá por tu dominio real
ALLOWED_ORIGIN=http://localhost:3000
